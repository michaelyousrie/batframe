{
    "name": "michaelyousrie/batframe",
    "description": "A tiny Flask-like PHP microframework where each public method is an endpoint and routes are inferred from method names.",
    "keywords": ["framework", "microframework", "router", "api", "flask", "blade"],
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "ext-json": "*",
        "eftec/bladeone": "^4.0",
        "vlucas/phpdotenv": "^5.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0"
    },
    "suggest": {
        "ext-pdo_sqlite": "To use the SQLite data storage driver. The default JSON driver needs nothing."
    },
    "autoload": {
        "psr-4": {
            "Batframe\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Batframe\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
